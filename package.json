{
  "name": "nanbox",
  "version": "3.0.0",
  "description": "Encode hidden data within NaN IEEE 754 floats",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "prepare": "npm run build",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "pretty": "prettier --write **/*.{ts,js,json}",
    "release": "np",
    "test": "node --experimental-strip-types --test src/**/__tests__/*.test.ts",
    "test:coverage": "node --experimental-strip-types --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage.lcov --test-reporter=spec --test-reporter-destination=stdout src/**/__tests__/*.test.ts"
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "/dist",
    "!/dist/**/__tests__/*"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philihp/nanbox.git"
  },
  "keywords": [
    "nan",
    "hidden",
    "payload"
  ],
  "author": "Philihp Busby <philihp@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/philihp/nanbox/issues"
  },
  "homepage": "https://github.com/philihp/nanbox#readme",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@philihp/prettier-config": "1.0.0",
    "@types/node": "22.10.5",
    "esbuild": "0.28.0",
    "eslint": "10.3.0",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.4",
    "prettier": "3.8.3",
    "tsup": "8.5.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.6.0"
  }
}
