{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    // tsup's dts build sets the baseUrl option, which TS 6 errors on without this
    "ignoreDeprecations": "6.0",
    "types": ["node"]
  },
  "include": ["src"]
}
